rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if request is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper to check user ID
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Helper to check admin/instructor role
    function isAdminOrInstructor() {
      return isAuthenticated() && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'instructor'
      );
    }

    // Users collection
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.auth.uid == userId;
      allow update: if isOwner(userId) || isAdminOrInstructor();
      allow delete: if isAdminOrInstructor();
    }

    // Courses collection
    match /courses/{courseId} {
      allow read: if true;
      allow write: if isAdminOrInstructor();
    }

    // Progress collection
    match /progress/{progressId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    // Certificates collection
    match /certificates/{certId} {
      allow read: if true; // Public verification allowed
      allow write: if isAdminOrInstructor();
    }
  }
}
